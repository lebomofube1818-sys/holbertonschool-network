#!/usr/bin/env bash
# This script configures localhost and facebook.com IP resolution

if [ "$(id -u)" -ne 0 ]; then
    sudo "$0" "$@"
    exit
fi

tmp_file=$(mktemp)

grep -v "127.0.0.1 localhost" /etc/hosts > "$tmp_file"
grep -v "127.0.0.2 localhost" "$tmp_file" > "${tmp_file}.2"
mv "${tmp_file}.2" "$tmp_file"

echo "127.0.0.2 localhost" >> "$tmp_file"
echo "8.8.8.8 facebook.com" >> "$tmp_file"

cat "$tmp_file" > /etc/hosts
rm "$tmp_file"
